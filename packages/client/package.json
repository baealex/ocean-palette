{
    "name": "@ocean-palette/client",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "start": "vite",
        "build": "tsc --noEmit && vite build",
        "preview": "vite preview",
        "type-check": "tsc --noEmit",
        "typecheck": "pnpm run type-check",
        "lint": "biome lint src",
        "react-compiler:check": "react-compiler-healthcheck --src \"src/**/*.{ts,tsx}\"",
        "test": "vitest run --passWithNoTests"
    },
    "dependencies": {
        "@baejino/react-ui": "^0.2.0",
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@radix-ui/react-hover-card": "^1.1.15",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-switch": "^1.2.6",
        "@tanstack/react-query": "^5.100.11",
        "@tanstack/react-router": "^1.170.6",
        "axios": "^1.16.1",
        "dayjs": "^1.11.20",
        "lucide-react": "^1.16.0",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "socket.io-client": "^4.8.3"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.15",
        "@tailwindcss/vite": "^4.3.0",
        "@tanstack/router-devtools": "^1.167.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "25.9.1",
        "@types/react": "^19.2.15",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.2",
        "babel-plugin-react-compiler": "^1.0.0",
        "jsdom": "^29.1.1",
        "react-compiler-healthcheck": "^1.0.0",
        "react-grab": "^0.1.37",
        "tailwindcss": "^4.3.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.14",
        "vitest": "^4.1.7"
    }
}
