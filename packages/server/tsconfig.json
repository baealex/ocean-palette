{
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": "src",
        "esModuleInterop": true,
        "module": "CommonJS",
        "moduleResolution": "Node",
        "baseUrl": "./src",
        "target": "ES2022",
        "ignoreDeprecations": "6.0",
        "types": ["node", "jest"],
        "paths": {
            "~/*": ["./*"]
        }
    },
    "include": ["src/**/*"],
    "exclude": ["scripts/**/*", "src/**/*.test.ts"],
    "ts-node": {
        "require": ["tsconfig-paths/register"]
    }
}
